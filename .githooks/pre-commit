#!/usr/bin/env bash
# Rebuild the chat UI bundle when its sources are staged.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
ui_dir="$repo_root/src/ui/client/chat"

# Only run if files under src/ui/client/chat/src/ are staged.
if ! git diff --cached --name-only | grep -q '^src/ui/client/chat/src/'; then
  exit 0
fi

if [ ! -d "$ui_dir/node_modules" ]; then
  echo "[pre-commit] Installing UI bundler deps..."
  (cd "$ui_dir" && npm install --silent --no-audit --no-fund)
fi

echo "[pre-commit] Rebuilding $ui_dir/dist/app.js..."
(cd "$ui_dir" && npm run --silent build)

git add "$ui_dir/dist/app.js" "$ui_dir/dist/app.js.map" 2>/dev/null || true
